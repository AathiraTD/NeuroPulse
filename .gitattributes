# Normalise line endings to LF in the repo, checkout as-is on all platforms
* text=auto eol=lf

# Binary files — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.pdf binary
*.docx binary
*.keystore binary
*.jks binary
*.zip binary
*.jar binary
*.apk binary
*.aab binary
